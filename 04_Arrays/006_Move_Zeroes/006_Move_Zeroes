def moveZeroes( nums):
        """
        Do not return anything, modify nums in-place instead.
        """
        L=-1
        for i in range(len(nums)):
            if nums[i]==0:
                L=i
                break
        
        for R in range(L+1,len(nums)):
            if nums[R]!=0 and nums[L]==0:
                nums[R], nums[L]=nums[L],nums[R]
                L=L+1

        return nums
print(moveZeroes([0,1,0,3,12]))
